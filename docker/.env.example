# ============================================================
# Dataplat dev stack — environment defaults
# Copy this file to docker/.env and fill in real secrets.
# The compose file loads this via env_file: .env.example so
# the stack works WITHOUT copying — defaults are safe for local dev.
# NEVER commit docker/.env (it is gitignored).
# ============================================================

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB_DAGSTER=platform_dagster

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=devpassword

# Dagster (used internally by FastAPI in F-004)
DAGSTER_GRAPHQL=http://dagster-webserver:3000/graphql

# LLM keys — not used until F-027/F-028/F-043; leave blank for F-001
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
