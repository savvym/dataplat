    "/api/auth/token": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Obtain a JWT access token",
        "description": "Validates email (submitted as `username`) and password via bcrypt. Returns a signed HS256 JWT on success. Returns HTTP 401 for incorrect credentials (same message whether the user is not found or the password is wrong \u2014 prevents email enumeration). Public route \u2014 all other API routes require Bearer <token> (F-008).",
        "operationId": "login_api_auth_token_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/Body_login_api_auth_token_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
